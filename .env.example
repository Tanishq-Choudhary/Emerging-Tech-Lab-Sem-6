# Server Configuration
PORT=${PORT:-3000}
NODE_ENV=${NODE_ENV:-development}

# Database Configuration
PG_HOST=${PG_HOST:-localhost}
PG_PORT=${PG_PORT:-5432}
PG_DATABASE=${PG_DATABASE:-codeatlas}
PG_USER=${PG_USER:-codeatlas}
PG_PASSWORD=${PG_PASSWORD:-codeatlas_dev}
PG_POOL_MAX=${PG_POOL_MAX:-20}

# Upload Configuration
UPLOAD_DIR=${UPLOAD_DIR:-./uploads}
MAX_FILE_SIZE=${MAX_FILE_SIZE:-10485760}
MAX_FILES=${MAX_FILES:-50}

# Integration Endpoints
RAG_ENGINE_URL=${RAG_ENGINE_URL:-http://localhost:8001}
RAG_TIMEOUT=${RAG_TIMEOUT:-30000}

# Ingestion Worker Settings
POLL_INTERVAL=${POLL_INTERVAL:-5000}
STALE_CHECK_INTERVAL=${STALE_CHECK_INTERVAL:-60000}
STALE_TIMEOUT_MINUTES=${STALE_TIMEOUT_MINUTES:-30}
MAX_CONCURRENT_JOBS=${MAX_CONCURRENT_JOBS:-1}

# Chunking Strategy
CHUNK_MAX_TOKENS=${CHUNK_MAX_TOKENS:-512}
CHUNK_OVERLAP=${CHUNK_OVERLAP:-64}
CHUNK_MIN_LINES=${CHUNK_MIN_LINES:-5}

# Observability
LOG_LEVEL=${LOG_LEVEL:-info}
